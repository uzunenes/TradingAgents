# LLM Providers (set the one you use)
LLM_PROVIDER=openrouter
BACKEND_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Alpaca Paper Trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Worker Configuration
TICKERS=SPY
UNIVERSE_MODE=fixed
SCREEN_TOP_N=8
SCREEN_CANDIDATE_POOL=20
SCREEN_LOOKBACK_DAYS=180
SCREEN_BATCH_SIZE=100
MIN_AVG_DOLLAR_VOLUME_USD=50000000
AGENTIC_SELECTION_ENABLED=true
AGENTIC_SELECTION_MODEL=
PORTFOLIO_INCLUDE_OPEN_POSITIONS=true
MAX_NEW_BUYS_PER_RUN=3
TRADING_ENABLED=true
MAX_ORDER_VALUE_USD=500
QUICK_MODEL=anthropic/claude-sonnet-4.6
FUNDAMENTALS_MODEL=google/gemini-3.1-pro-preview
DEEP_MODEL=openai/gpt-5.4
RUN_ON_START=false
SCHEDULER_ENABLED=true
HTTP_ENABLED=false
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
# Optional intraday schedule, for example: 14:00,17:00,19:45
SCHEDULE_TIMES_UTC=
# Legacy single-run schedule fallback when SCHEDULE_TIMES_UTC is empty
SCHEDULE_HOUR_UTC=21
SCHEDULE_MINUTE_UTC=5
LOG_LEVEL=INFO

# Telegram Notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
